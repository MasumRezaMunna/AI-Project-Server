# Port the Express API listens on
PORT=4000

# Comma-separated list of allowed origins for CORS (your Next.js app)
CLIENT_ORIGIN=http://localhost:3000

# --- MongoDB (Atlas free M0 tier — no credit card required) ---
# Get a connection string from https://cloud.mongodb.com after creating a
# free cluster: Database > Connect > Drivers, then paste it here and replace
# <password> with your database user's password.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/wanderlust-trails

# --- Firebase Admin SDK (verifies the ID tokens the client sends) ---
# In the Firebase console: Project settings > Service accounts > Generate
# new private key. That downloads a JSON file — copy the three fields below
# out of it. Keep the surrounding quotes around the private key.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# --- Google Gemini (free tier) — powers both AI features ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
